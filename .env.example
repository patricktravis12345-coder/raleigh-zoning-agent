# Copy this file to .env and fill in real values.
# .env is gitignored -- never commit real API keys.

# Found via scripts/find_endpoint.py
ZONING_CASES_LAYER_URL=

# Google Maps JavaScript API key (see SETUP.md for how to get one)
GOOGLE_MAPS_API_KEY=

# Optional: narrows the ArcGIS query if the source layer covers more than
# just Raleigh (e.g. all of Wake County). Leave as 1=1 if the layer is
# already Raleigh-only.
EXTRA_WHERE_CLAUSE=1=1

# Set to false while testing, so the script doesn't commit/push automatically
GIT_AUTO_COMMIT=true
GIT_AUTO_PUSH=true
